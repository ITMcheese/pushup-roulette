{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/www/css/$1" },
    { "source": "/js/(.*)", "destination": "/www/js/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/manifest.json", "destination": "/www/manifest.json" },
    { "source": "/sw.js", "destination": "/www/sw.js" },
    { "source": "/favicon.svg", "destination": "/www/favicon.svg" },
    { "source": "/(.*)", "destination": "/www/index.html" }
  ]
}
